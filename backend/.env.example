# ─────────────────────────────────────────────
# Backend NoMask — Variables d'environnement
# Copie ce fichier : cp .env.example .env
# ─────────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://rmhjnljlatmtlwilrvuz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta_clé_anon
SUPABASE_SERVICE_ROLE_KEY=ta_clé_service_role

# Ollama — quand le backend tourne en Docker, Ollama est sur la machine hôte
# Utilise host.docker.internal pour que Docker atteigne le host
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120

# Parallélisme
MAX_CONCURRENT_SCRAPES=5
MAX_CONCURRENT_IMAGE_DOWNLOADS=10
